# Hans AI Dashboard - Local Development Environment Variables
# Copy this file to .env.local and update with your values

# Subscriptions Service (Payment Analytics)
SUBSCRIPTIONS_URL=http://localhost:8001

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Mem0 Server
NEXT_PUBLIC_MEM0_URL=http://localhost:8002

# Python Backend (WhatsApp Webhook) - For voice samples with Edge TTS
# Uncomment this when you want to use real audio generation
# PYTHON_BACKEND_URL=http://localhost:8003

# MongoDB Logger (Chat Logs)
NEXT_PUBLIC_MONGO_LOGGER_URL=https://tkgsogkk4cg4wkgok0cw4gk8.api.hansastro.com

# Qdrant
NEXT_PUBLIC_QDRANT_URL=http://localhost:6333

# Application
NODE_ENV=development

# Dashboard Authentication
DASHBOARD_PASSWORD=your_dashboard_password_here

# Groq API (for single user friendship scoring)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# DeepSeek API (for batch friendship scoring - recommended)
# Get your API key from: https://platform.deepseek.com/
# Pricing: V4 Flash - $0.14/M input, $0.28/M output
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Z.AI API (for real-time friendship scoring - FREE, GLM models)
# OpenAI-compatible API at https://api.z.ai
# Get your key from your Z.AI dashboard
ZAI_API_KEY=your_zai_api_key_here
